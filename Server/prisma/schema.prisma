generator client {
  provider             = "prisma-client-py"
  interface            = "asyncio"
  recursive_type_depth = 5
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(auto()) @map("_id") @db.ObjectId
  email            String            @unique
  password         String
  name             String
  createdAt        DateTime          @default(now())
  scans            Scan[]
  behavioralAlerts BehavioralAlert[]
}

model Scan {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])
  scanType    String   // "url", "pdf", "file", "image"
  target      String   // URL or filename
  status      String   // "pending", "scanning", "completed", "failed"
  result      Json?    // Scan results
  threatLevel String?  // "clean", "low", "medium", "high", "critical"
  startTime   DateTime @default(now())
  endTime     DateTime?
  createdAt   DateTime @default(now())
}

model BehavioralAlert {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  processName String
  pid         Int
  riskScore   Float
  tier        String   // CLEAN, MONITOR, SUSPICIOUS, ALERT
  features    Json     // {fe, fa, fn, fc}
  timestamp   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model ProcessBaseline {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  processName String   @unique
  baseline    Json     // {mean, covariance}
  updatedAt   DateTime @updatedAt
}
